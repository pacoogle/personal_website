# Copia in `.env.local` o imposta su GitHub Actions / hosting del build.
#
# Buttondown: solo username → il sito apre buttondown.com/?tag=... (evita blocked:origin
# su POST da domini tipo GitHub Pages). Per un form POST custom usa
# NEXT_PUBLIC_NEWSLETTER_FORM_ACTION.
NEXT_PUBLIC_BUTTONDOWN_USERNAME=
NEXT_PUBLIC_NEWSLETTER_TAG=

# NEXT_PUBLIC_NEWSLETTER_FORM_ACTION=https://...

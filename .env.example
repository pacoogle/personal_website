# Copia in `.env.local` o imposta nei secret del build (GitHub / Vercel).

# Username newsletter Buttondown → form embed:
# POST https://buttondown.com/api/emails/embed-subscribe/{username}
NEXT_PUBLIC_BUTTONDOWN_USERNAME=

# Tag iscritti (default nel codice: sbobinature se vuoto)
NEXT_PUBLIC_NEWSLETTER_TAG=

# In alternativa: action URL di un altro provider (ha priorità sullo username).
# NEXT_PUBLIC_NEWSLETTER_FORM_ACTION=

# Export statico / GitHub Pages (se usi basePath sul repo)
# PAGES_BASE_PATH=
# PAGES_ASSET_PREFIX=
